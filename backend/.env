# FastAPI Config
HOST=127.0.0.1
PORT=8000

# Vector DB
VECTOR_DB=chroma
CHROMA_DB_PATH=./backend/data/embeddings

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# File Upload Limit
MAX_FILE_SIZE_MB=10

# Tesseract OCR Path
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
